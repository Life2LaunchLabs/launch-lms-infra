# ── Site ──────────────────────────────────────────────
LEARNHOUSE_SITE_NAME=
LEARNHOUSE_SITE_DESCRIPTION=
LEARNHOUSE_CONTACT_EMAIL=

# ── Hosting ───────────────────────────────────────────
LEARNHOUSE_DOMAIN=
LEARNHOUSE_FRONTEND_DOMAIN=
LEARNHOUSE_SSL=true
LEARNHOUSE_PORT=9000
LEARNHOUSE_USE_DEFAULT_ORG=true
LEARNHOUSE_SELF_HOSTED=true
LEARNHOUSE_ALLOWED_ORIGINS=
LEARNHOUSE_ALLOWED_REGEXP=
LEARNHOUSE_COOKIE_DOMAIN=
LEARNHOUSE_ENV=prod

# ── Security ──────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
LEARNHOUSE_AUTH_JWT_SECRET_KEY=
COLLAB_INTERNAL_KEY=
LEARNHOUSE_INITIAL_ADMIN_PASSWORD=

# ── Database ──────────────────────────────────────────
# Local docker-compose Postgres (default)
LEARNHOUSE_SQL_CONNECTION_STRING=postgresql+asyncpg://learnhouse:${POSTGRES_PASSWORD}@db:5432/learnhouse
# DO Managed PostgreSQL: postgresql+asyncpg://user:pass@host:25060/learnhouse?ssl=require

# ── Redis ─────────────────────────────────────────────
# Local docker-compose Redis (default)
LEARNHOUSE_REDIS_CONNECTION_STRING=redis://redis:6379
# DO Managed Redis: rediss://default:pass@host:25061

# ── Postgres password (used by the db service) ────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=

# ── Email ─────────────────────────────────────────────
LEARNHOUSE_EMAIL_PROVIDER=resend
LEARNHOUSE_RESEND_API_KEY=
LEARNHOUSE_SYSTEM_EMAIL_ADDRESS=

# ── Content delivery ──────────────────────────────────
# Use s3api for production, filesystem for simple setups
LEARNHOUSE_CONTENT_DELIVERY_TYPE=s3api
LEARNHOUSE_S3_API_BUCKET_NAME=
LEARNHOUSE_S3_API_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AI (optional) ─────────────────────────────────────
LEARNHOUSE_IS_AI_ENABLED=false
LEARNHOUSE_GEMINI_API_KEY=

# ── Payments (optional) ───────────────────────────────
LEARNHOUSE_STRIPE_SECRET_KEY=
LEARNHOUSE_STRIPE_PUBLISHABLE_KEY=
LEARNHOUSE_STRIPE_WEBHOOK_STANDARD_SECRET=
LEARNHOUSE_STRIPE_WEBHOOK_CONNECT_SECRET=

# ── Analytics (optional) ──────────────────────────────
LEARNHOUSE_TINYBIRD_API_URL=
LEARNHOUSE_TINYBIRD_INGEST_TOKEN=
LEARNHOUSE_TINYBIRD_READ_TOKEN=

# ── Code execution (optional) ─────────────────────────
LEARNHOUSE_JUDGE0_API_URL=
LEARNHOUSE_JUDGE0_CLIENT_ID=
LEARNHOUSE_JUDGE0_CLIENT_SECRET=
