# ── Site ──────────────────────────────────────────────
LAUNCHLMS_SITE_NAME=
LAUNCHLMS_SITE_DESCRIPTION=
LAUNCHLMS_CONTACT_EMAIL=

# ── Hosting ───────────────────────────────────────────
LAUNCHLMS_DOMAIN=
LAUNCHLMS_FRONTEND_DOMAIN=
LAUNCHLMS_SSL=false
LAUNCHLMS_PORT=9000
LAUNCHLMS_USE_DEFAULT_ORG=true
LAUNCHLMS_SELF_HOSTED=true
LAUNCHLMS_ALLOWED_ORIGINS=
LAUNCHLMS_ALLOWED_REGEXP=
LAUNCHLMS_COOKIE_DOMAIN=
LAUNCHLMS_ENV=prod

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_LAUNCHLMS_DOMAIN=
NEXT_PUBLIC_LAUNCHLMS_API_URL=https://yourdomain.com/api/v1/
NEXT_PUBLIC_LAUNCHLMS_BACKEND_URL=https://yourdomain.com/
LAUNCHLMS_INTERNAL_API_URL=http://localhost/api/v1/
NEXT_PUBLIC_LAUNCHLMS_HTTPS=true
NEXT_PUBLIC_LAUNCHLMS_DEFAULT_ORG=
NEXT_PUBLIC_COLLAB_URL=wss://yourdomain.com/collab

# ── Security ──────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
LAUNCHLMS_AUTH_JWT_SECRET_KEY=
COLLAB_INTERNAL_KEY=
LAUNCHLMS_INITIAL_ADMIN_EMAIL=
LAUNCHLMS_INITIAL_ADMIN_PASSWORD=

# ── Database ──────────────────────────────────────────
# Local docker-compose Postgres (default)
LAUNCHLMS_SQL_CONNECTION_STRING=postgresql+psycopg2://launchlms:${POSTGRES_PASSWORD}@db:5432/launchlms
# DO Managed PostgreSQL: postgresql+psycopg2://user:pass@host:25060/launchlms?ssl=require
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────
# Local docker-compose Redis (default)
LAUNCHLMS_REDIS_CONNECTION_STRING=redis://redis:6379/launchlms
# DO Managed Redis: rediss://default:pass@host:25061

# ── Email ─────────────────────────────────────────────
LAUNCHLMS_EMAIL_PROVIDER=resend
LAUNCHLMS_RESEND_API_KEY=
LAUNCHLMS_SYSTEM_EMAIL_ADDRESS=

# ── Content delivery ──────────────────────────────────
# Use s3api for production, filesystem for simple setups
LAUNCHLMS_CONTENT_DELIVERY_TYPE=filesystem
LAUNCHLMS_S3_API_BUCKET_NAME=
LAUNCHLMS_S3_API_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AI (optional) ─────────────────────────────────────
LAUNCHLMS_IS_AI_ENABLED=false
LAUNCHLMS_GEMINI_API_KEY=

# ── Payments (optional) ───────────────────────────────
LAUNCHLMS_STRIPE_SECRET_KEY=
LAUNCHLMS_STRIPE_PUBLISHABLE_KEY=
LAUNCHLMS_STRIPE_WEBHOOK_STANDARD_SECRET=
LAUNCHLMS_STRIPE_WEBHOOK_CONNECT_SECRET=

# ── Analytics (optional) ──────────────────────────────
LAUNCHLMS_TINYBIRD_API_URL=
LAUNCHLMS_TINYBIRD_INGEST_TOKEN=
LAUNCHLMS_TINYBIRD_READ_TOKEN=

# ── Code execution (optional) ─────────────────────────
LAUNCHLMS_JUDGE0_API_URL=
LAUNCHLMS_JUDGE0_CLIENT_ID=
LAUNCHLMS_JUDGE0_CLIENT_SECRET=
